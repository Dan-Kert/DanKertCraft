# === Скомпилированный код и билды ===
# Мы игнорируем папки сборки, но оставляем исходники
target/
out/
build/
bin/

# Игнорируем отдельные скомпилированные файлы
*.class
*.war
*.jar
*.ear

# ИСКЛЮЧЕНИЕ: Если ты хочешь хранить библиотеку GSON в libs,
# снимаем игнор с этой конкретной папки
!libs/*.jar

# === Настройки IDE (IntelliJ IDEA) ===
.idea/
*.iml
*.iws
*.ipr

# === Логи и временные файлы ===
*.log
app.log
logs/
temp/
tmp/
.cache/

# === Специфичные файлы ОС ===
.DS_Store
Thumbs.db